generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 枚举
// ============================================================

/// Agent 容器运行状态
enum AgentStatus {
  created           // 刚创建，尚未启动
  starting          // 正在拉起 OpenClaw 容器
  running           // 容器运行中
  stopped           // 用户主动停止
  error             // 容器崩溃或启动失败
  api_key_exhausted // API Key 余额不足
}

// ============================================================
// Agent 表
// ============================================================

/// Agent 主表 —— 每个 Agent 对应 im-server 中一个 Account(type=agent)
/// accountId 是跨服务的共享标识符
model Agent {
  id           String      @id @default(uuid())
  accountId    String      @unique        // 对应 im-server Account.id
  ownerId      String                     // 创建者（人类用户）的 Account.id
  parentId     String?                    // 父级 Agent 的 id（支持 Agent 树）
  name         String                     // 显示名称（同步到 im-server）
  avatar       String?                    // 头像 URL
  createdAt    DateTime    @default(now())

  config AgentConfig?                     // 1:1 配置
  parent Agent?   @relation("AgentTree", fields: [parentId], references: [id])
  children Agent[] @relation("AgentTree")
}

/// Agent 配置 —— 模型、API Key、OpenClaw 容器信息
model AgentConfig {
  id           String      @id @default(uuid())
  agentId      String      @unique
  model        String                     // 模型名称（如 anthropic/claude-sonnet-4-6）
  apiKey       String?                    // 加密存储的 API Key
  inheritKey   Boolean     @default(true) // 是否继承 owner 的 API Key
  systemPrompt String?                    // Agent 性格/系统提示词

  // OpenClaw 容器信息
  containerId  String?                    // Docker 容器 ID
  volumeName   String?                    // Docker Volume 名称
  gatewayToken String?                    // OpenClaw Gateway 连接 Token
  status       AgentStatus @default(created)
  startedAt    DateTime?                  // 最近启动时间
  stoppedAt    DateTime?                  // 最近停止时间

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}
