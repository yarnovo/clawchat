# ClawChat Agent — openclaw:local + clawchat channel extension
# Build context: project root
# Usage: docker build -f openclaw-server/Dockerfile.agent -t openclaw-agent:local .

FROM openclaw:local

# Copy ClawChat channel extension
COPY openclaw-server/extensions/clawchat/ /app/extensions/clawchat/

# Entrypoint script for config injection
USER root
COPY openclaw-server/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
USER node

# Gateway (18789) + ClawChat webhook (18790)
EXPOSE 18789 18790

HEALTHCHECK --interval=3m --timeout=10s --start-period=15s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:18789/healthz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
