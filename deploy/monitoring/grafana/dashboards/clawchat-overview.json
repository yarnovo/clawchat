{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Logs (All)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"$service\"} | json | level = `error` or level = `50`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    },
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\"} | json | level = `error` or level = `50` [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request ID Trace",
      "description": "Search by request ID to trace across services",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\".+\"} |~ \"$requestId\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Ascending",
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["clawchat"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(service)",
        "datasource": { "type": "loki", "uid": "loki" },
        "type": "query",
        "refresh": 2
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "name": "search",
        "type": "textbox",
        "label": "Search"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "name": "requestId",
        "type": "textbox",
        "label": "Request ID"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ClawChat Overview",
  "uid": "clawchat-overview"
}
